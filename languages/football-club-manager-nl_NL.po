msgid "Signup Form - Parent Details"
msgstr "Inschrijfformulier - Ouder details"

#: blocks/signup-form-parent-details/block.json
#: build/signup-form-parent-details/block.json
msgctxt "block description"
msgid ""
"Add parent details fields to the signup form. This block should be used "
